[Unit]
Description=RFM69 to MQTT Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dietpi
WorkingDirectory=/home/dietpi/rfm69-pi-avr/hub-pi
ExecStart=/home/dietpi/rfm69-pi-avr/hub-pi/venv/bin/python3 gateway.py --log-file /var/log/rfm69-gateway.log
Restart=on-failure
RestartSec=10
ExecStartPre=/bin/sleep 5

[Install]
WantedBy=multi-user.target